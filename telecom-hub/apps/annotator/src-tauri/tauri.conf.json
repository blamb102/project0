{
  "productName": "Patent Figure Annotator",
  "version": "0.1.0",
  "identifier": "com.telecomhub.annotator",
  "build": {
    "beforeDevCommand": "cross-env TAURI_BUILD=1 pnpm dev",
    "devUrl": "http://localhost:3003",
    "beforeBuildCommand": "cross-env TAURI_BUILD=1 pnpm build",
    "frontendDist": "../out"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Patent Figure Annotator",
        "width": 1440,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
